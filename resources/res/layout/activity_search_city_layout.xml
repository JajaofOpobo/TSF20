<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="10dp">
        <EditText android:textSize="16sp" android:textColor="@color/material_item_text_color" android:id="@+id/edittext_cityname" android:background="@drawable/material_edit_text_background" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginLeft="10dp" android:hint="@string/tapcityname" android:maxLines="1" android:singleLine="true" android:maxLength="40" android:layout_weight="1"/>
        <ImageView android:id="@+id/imageButton1" android:background="@drawable/activity_list_bg_selector" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="10dp" android:layout_marginRight="10dp" android:src="@drawable/activity_ico_search" android:tint="@color/material_catalog_color"/>
    </LinearLayout>
    <ListView android:id="@+id/searchcity_list" android:layout_width="match_parent" android:layout_height="match_parent" style="@style/TSFTheme.Material.ListViewStyle"/>
</LinearLayout>
