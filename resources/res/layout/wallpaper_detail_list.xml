<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:ptr="http://schemas.android.com/apk/res-auto" android:orientation="vertical" android:background="#ffffffff" android:layout_width="match_parent" android:layout_height="match_parent">
    <com.tsf.extend.theme.ThemePullToRefreshListView android:id="@+id/detail_list" android:fadingEdge="none" android:layout_width="match_parent" android:layout_height="match_parent" android:listSelector="@color/transparent" android:cacheColorHint="#00000000" android:divider="@color/transparent" android:fastScrollEnabled="false" android:headerDividersEnabled="false" android:footerDividersEnabled="false" android:smoothScrollbar="true" ptr:ptrMode="pullFromStart" ptr:ptrAnimationStyle="flip"/>
    <LinearLayout android:orientation="vertical" android:id="@+id/no_data_layout" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="320dp" android:layout_alignParentBottom="true">
        <TextView android:textSize="15sp" android:textColor="#99333333" android:gravity="center" android:id="@+id/main_more_theme_fail" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/wallpaper_detail_view_more_fail" android:layout_weight="1"/>
        <View android:background="#ffe5e5e5" android:layout_width="match_parent" android:layout_height="0.5dp"/>
        <TextView android:textSize="16sp" android:textColor="#ffffff" android:gravity="center" android:id="@+id/main_more_theme" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginLeft="@dimen/theme_detail_padding_left" android:layout_marginTop="8dp" android:layout_marginRight="@dimen/theme_detail_padding_left" android:layout_marginBottom="8dp" android:text="@string/wallpaper_detail_view_more"/>
    </LinearLayout>
    <RelativeLayout android:id="@+id/wallpaper_bigtype_layout" android:visibility="gone" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent">
        <com.tsf.extend.wallpaper.WallpaperImageView android:id="@+id/wallpaper_bigtype_img" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <ProgressBar android:id="@+id/wallpaper_bigtype_progresbar" android:layout_width="70dp" android:layout_height="70dp" android:layout_centerInParent="true"/>
        <LinearLayout android:orientation="vertical" android:id="@+id/wallpaper_bigtype_retry" android:background="@drawable/retry_bg" android:paddingLeft="15dp" android:paddingRight="15dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="80dp" android:minWidth="80dp" android:layout_centerInParent="true">
            <ImageView android:layout_gravity="center" android:id="@+id/wallpaper_bigtype_refresh_icon" android:duplicateParentState="true" android:layout_width="30dp" android:layout_height="30dp" android:layout_marginTop="17dp" android:src="@drawable/icon_btn_refresh"/>
            <TextView android:textSize="16dp" android:textColor="@drawable/wallpaper_detail_retry_text_color" android:ellipsize="end" android:layout_gravity="center" android:id="@+id/wallpaper_bigtype_retry_text" android:duplicateParentState="true" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:maxWidth="176dp" android:text="@string/detail_retry" android:singleLine="true"/>
        </LinearLayout>
        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
            <TextView android:textSize="15sp" android:textColor="@android:color/white" android:id="@+id/wallpaper_bigtype_wallpaper_progress" android:background="@android:color/transparent" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true"/>
        </RelativeLayout>
        <RelativeLayout android:gravity="center_vertical" android:id="@+id/wallpaper_bigtype_author_layout" android:layout_width="match_parent" android:layout_height="48dp" android:layout_above="@+id/wallpaper_bigtype_action_layout">
            <FrameLayout android:id="@+id/wallpaper_bigtype_expand_panel" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:layout_centerVertical="true">
                <TextView android:textSize="12sp" android:textColor="#ffffff" android:layout_gravity="center_vertical" android:id="@+id/wallpaper_bigtype_author" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </FrameLayout>
        </RelativeLayout>
        <RelativeLayout android:id="@+id/wallpaper_bigtype_action_layout" android:background="#4d000000" android:clickable="true" android:layout_width="match_parent" android:layout_height="48dp" android:layout_alignParentBottom="true">
            <View android:background="#4dffffff" android:layout_width="match_parent" android:layout_height="0.5dp"/>
            <ImageView android:id="@+id/wallpaper_bigtype_preview" android:paddingLeft="24dp" android:paddingRight="24dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true"/>
            <TextView android:textSize="16sp" android:textColor="@drawable/set_wallpaper_text_color" android:ellipsize="end" android:gravity="center" android:id="@+id/wallpaper_bigtype_set_wallpaper" android:paddingLeft="24dp" android:paddingRight="24dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/set_as_wallpaper" android:maxLines="2" android:layout_weight="1" android:layout_centerInParent="true"/>
            <ImageView android:gravity="center" android:id="@+id/wallpaper_bigtype_favorite" android:visibility="gone" android:layout_width="30dp" android:layout_height="30dp" android:layout_marginLeft="24dp" android:layout_marginRight="24dp" android:src="@drawable/favorite_theme_selector" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
            <ImageView android:id="@+id/wallpaper_bigtype_delete" android:paddingLeft="24dp" android:paddingRight="24dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/ic_launcher_clear_normal_holo" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>
