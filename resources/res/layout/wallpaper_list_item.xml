<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="horizontal" android:paddingLeft="@dimen/wallpaper_list_padding_horizontal" android:paddingRight="@dimen/wallpaper_list_padding_horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
    <FrameLayout android:id="@+id/live" android:background="#ffffc400" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content">
        <TextView android:textSize="17sp" android:textColor="#ffffffff" android:gravity="center" android:layout_gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/live" android:singleLine="true" android:drawableTop="@drawable/wallpaper_mine_live" android:drawablePadding="3dp"/>
    </FrameLayout>
    <FrameLayout android:id="@+id/left_group" android:layout_width="wrap_content" android:layout_height="wrap_content">
        <ImageView android:id="@+id/img_left" android:background="@color/personal_list_item_bg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:scaleType="fitXY"/>
        <TextView android:textSize="12sp" android:textColor="#bfffffff" android:gravity="center_vertical" android:layout_gravity="top|right" android:id="@+id/download_left" android:background="@drawable/wp_downloads" android:paddingLeft="20dp" android:paddingTop="0dp" android:paddingRight="8dp" android:paddingBottom="0dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="20dp" android:layout_marginTop="5dp" android:layout_marginRight="5dp"/>
        <ImageView android:layout_gravity="bottom|right" android:id="@+id/user_tag_left" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="5dp" android:layout_marginBottom="5dp" android:src="@drawable/wp_photowall"/>
        <ImageView android:layout_gravity="top|right" android:id="@+id/live_tag_left" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/ic_live_wp_flag"/>
        <TextView android:textSize="12sp" android:textColor="#ffffff" android:ellipsize="end" android:gravity="center_vertical" android:id="@+id/time" android:background="#3d3d3d" android:paddingLeft="8dp" android:paddingRight="8dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="25dp" android:layout_marginTop="13dp" android:singleLine="true"/>
    </FrameLayout>
    <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
        <ImageView android:id="@+id/img_right" android:background="@color/personal_list_item_bg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:scaleType="fitXY"/>
        <TextView android:textSize="12sp" android:textColor="#bfffffff" android:gravity="center_vertical" android:layout_gravity="top|right" android:id="@+id/download_right" android:background="@drawable/wp_downloads" android:paddingLeft="20dp" android:paddingTop="0dp" android:paddingRight="8dp" android:paddingBottom="0dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="20dp" android:layout_marginTop="5dp" android:layout_marginRight="5dp"/>
        <ImageView android:layout_gravity="bottom|right" android:id="@+id/user_tag_right" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="5dp" android:layout_marginBottom="5dp" android:src="@drawable/wp_photowall"/>
        <ImageView android:layout_gravity="top|right" android:id="@+id/live_tag_right" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/ic_live_wp_flag"/>
    </FrameLayout>
</LinearLayout>
