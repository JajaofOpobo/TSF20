<?xml version="1.0" encoding="utf-8"?>
<com.tsf.extend.theme.ThemeDetail xmlns:android="http://schemas.android.com/apk/res/android" xmlns:ptr="http://schemas.android.com/apk/res-auto" android:paddingTop="@dimen/workspace_margin_top" android:layout_width="match_parent" android:layout_height="match_parent">
