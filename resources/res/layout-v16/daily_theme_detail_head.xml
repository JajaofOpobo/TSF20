<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:orientation="vertical" android:id="@+id/theme_detail" android:layout_width="match_parent" android:layout_height="wrap_content">
        <FrameLayout android:id="@+id/pager_container" android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.tsf.extend.theme.ThemeDetailViewPager android:layout_gravity="bottom" android:id="@+id/head_viewpager" android:layout_width="match_parent" android:layout_height="@dimen/theme_detail_pager_height" android:layout_marginBottom="73dp"/>
            <ImageView android:layout_gravity="bottom|center_horizontal" android:id="@+id/phone_cover" android:background="@drawable/theme_phone_cover" android:layout_width="@dimen/theme_detail_phone_cover_width" android:layout_height="@dimen/theme_detail_phone_cover_height" android:layout_marginTop="40dp" android:layout_marginBottom="42dp" android:scaleType="fitXY"/>
            <Button android:textSize="16sp" android:textColor="#ffffffff" android:layout_gravity="bottom|center_horizontal" android:id="@+id/btn_free_download" android:background="@drawable/btn_download" android:paddingTop="5dp" android:layout_width="255dp" android:layout_height="60dp" android:layout_marginLeft="42dp" android:layout_marginRight="42dp" android:layout_marginBottom="27dp" android:text="@string/daily_theme_download"/>
            <RelativeLayout android:id="@+id/headerl_ll" android:background="@drawable/tv_bg_dailytheme" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <com.tsf.extend.base.view.RotateTextView android:textSize="16sp" android:textColor="#ffffffff" android:padding="0dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="6dp" android:layout_marginTop="0dp" android:text="BEST   THEME" app:rotate_degree="225dp"/>
                <com.tsf.extend.base.view.RotateTextView android:textSize="27sp" android:textColor="#ffffffff" android:padding="0dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="30dp" android:layout_marginTop="22dp" android:text="TODAY" app:rotate_degree="225dp"/>
            </RelativeLayout>
            <TextView android:textColor="#ffffff" android:layout_gravity="bottom" android:id="@+id/daily_theme_detail_head_you_might_like" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="@dimen/theme_detail_padding_left" android:layout_marginTop="14dp" android:layout_marginBottom="2dp" android:text="@string/daily_theme_might_like"/>
        </FrameLayout>
        <LinearLayout android:orientation="vertical" android:paddingLeft="@dimen/theme_detail_padding_left" android:paddingRight="@dimen/theme_detail_padding_left" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:id="@+id/diy_theme_promotion" android:background="@drawable/diy_contribute_bubble" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                <TextView android:textSize="12sp" android:textColor="#333333" android:gravity="center" android:layout_gravity="left" android:paddingLeft="16dp" android:paddingTop="8dp" android:paddingRight="16dp" android:paddingBottom="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/theme_guideto_share_bubble" android:fontFamily="OpenSans-Light"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
