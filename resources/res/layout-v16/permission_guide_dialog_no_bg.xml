<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" android:gravity="center_horizontal" android:background="@drawable/perm_guide_layout_bg" android:layout_width="match_parent" android:layout_height="match_parent">
    <TextView android:textSize="15sp" android:textColor="#000000" android:layout_gravity="bottom|center_horizontal" android:id="@+id/perm_desc" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="20dp" android:layout_marginTop="20dp" android:layout_marginRight="20dp" android:layout_marginBottom="20dp" android:lineSpacingExtra="4dp" android:fontFamily="sans-serif-light"/>
    <View android:background="#32000000" android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_below="@+id/perm_desc"/>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="48dp" android:layout_below="@+id/perm_desc">
        <TextView android:textSize="16sp" android:textColor="#000000" android:gravity="center" android:id="@+id/iv_close" android:layout_width="0dp" android:layout_height="match_parent" android:text="@string/dialog_cancel" android:layout_weight="1"/>
        <View android:id="@+id/seprator" android:background="#32000000" android:layout_width="0.5dp" android:layout_height="match_parent"/>
        <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="#4480f7" android:gravity="center" android:id="@+id/perm_ok" android:layout_width="0dp" android:layout_height="match_parent" android:text="OK" android:layout_weight="1"/>
    </LinearLayout>
</RelativeLayout>
