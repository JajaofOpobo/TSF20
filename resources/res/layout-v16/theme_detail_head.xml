<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:orientation="vertical" android:id="@+id/theme_detail" android:layout_width="match_parent" android:layout_height="wrap_content">
        <FrameLayout android:id="@+id/pager_container" android:background="#ffffffff" android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.tsf.extend.theme.ThemeDetailViewPager android:layout_gravity="bottom" android:id="@+id/theme_preview_pager" android:layout_width="match_parent" android:layout_height="@dimen/theme_detail_pager_height" android:layout_marginTop="16dp"/>
            <ImageView android:layout_gravity="bottom|center_horizontal" android:id="@+id/phone_cover" android:background="@drawable/theme_phone_cover" android:layout_width="@dimen/theme_detail_phone_cover_width" android:layout_height="@dimen/theme_detail_phone_cover_height" android:layout_marginTop="15dp" android:layout_marginBottom="-30dp" android:scaleType="fitXY"/>
            <LinearLayout android:layout_gravity="bottom" android:orientation="horizontal" android:id="@+id/theme_info_bar" android:background="@drawable/theme_detail_name_bg" android:paddingLeft="@dimen/theme_detail_padding_left" android:paddingTop="8dp" android:paddingRight="@dimen/theme_detail_padding_left" android:paddingBottom="8dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:textSize="13sp" android:textColor="#ffffffff" android:id="@+id/theme_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="OpenSans-Light"/>
                <TextView android:textSize="13sp" android:textColor="#ffffffff" android:ellipsize="end" android:id="@+id/theme_author" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:maxLines="1" android:fontFamily="OpenSans-Light"/>
            </LinearLayout>
        </FrameLayout>
        <LinearLayout android:orientation="vertical" android:background="#ffffffff" android:paddingLeft="@dimen/theme_detail_padding_left" android:paddingRight="@dimen/theme_detail_padding_left" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:id="@+id/diy_theme_promotion" android:background="@drawable/diy_contribute_bubble" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                <TextView android:textSize="12sp" android:textColor="#333333" android:gravity="center" android:layout_gravity="left" android:paddingLeft="16dp" android:paddingTop="8dp" android:paddingRight="16dp" android:paddingBottom="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/theme_guideto_share_bubble" android:fontFamily="OpenSans-Light"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <View android:id="@+id/theme_head_divider" android:background="#ffe5e5e5" android:layout_width="match_parent" android:layout_height="0.5dp"/>
    <TextView android:id="@+id/load_relevance_tips" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="@dimen/theme_detail_padding_left" android:layout_marginTop="12dp" android:layout_marginBottom="2dp" android:text="@string/theme_detial_recommend"/>
</LinearLayout>
