<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" android:gravity="center_horizontal" android:background="@drawable/perm_guide_layout_bg" android:layout_width="match_parent" android:layout_height="match_parent">
    <ImageView android:id="@+id/bg" android:layout_width="match_parent" android:layout_height="wrap_content" android:scaleType="centerCrop"/>
    <ImageView android:id="@+id/iv_close" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:layout_marginRight="6dp" android:src="@drawable/perm_ic_close" android:scaleType="fitXY" android:layout_alignParentTop="true" android:layout_alignParentRight="true"/>
    <TextView android:textSize="15sp" android:textColor="#333333" android:layout_gravity="bottom|center_horizontal" android:id="@+id/perm_desc" android:paddingLeft="10dp" android:paddingRight="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="15dp" android:layout_marginBottom="15dp" android:layout_below="@+id/bg" android:lineSpacingExtra="4dp" android:fontFamily="sans-serif-light"/>
    <View android:background="#32000000" android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_below="@+id/perm_desc"/>
    <TextView android:textSize="16sp" android:textColor="#4480f7" android:gravity="center" android:id="@+id/perm_ok" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="15dp" android:layout_marginBottom="15dp" android:text="@string/btn_ok_perm" android:layout_below="@+id/perm_desc"/>
</RelativeLayout>
