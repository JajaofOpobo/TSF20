<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="64dp">
    <RelativeLayout android:layout_gravity="center_vertical" android:id="@+id/theme_notify_img_container" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginLeft="8dp">
        <ImageView android:id="@+id/theme_notify_type_icon" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/theme" android:scaleType="centerInside" android:layout_centerInParent="true"/>
    </RelativeLayout>
    <LinearLayout android:gravity="top" android:layout_gravity="center_vertical" android:orientation="vertical" android:paddingTop="2dp" android:paddingBottom="2dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="50dp" android:minHeight="40dp" android:paddingEnd="8dp">
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:layout_marginTop="6dp">
            <TextView android:textAppearance="@android:style/TextAppearance.StatusBar.EventContent.Title" android:ellipsize="marquee" android:id="@+id/theme_notify_title" android:fadingEdge="horizontal" android:layout_width="0dp" android:layout_height="wrap_content" android:singleLine="true" android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="8dp">
            <TextView android:textAppearance="@android:style/TextAppearance.StatusBar.EventContent" android:ellipsize="end" android:layout_gravity="center" android:id="@+id/theme_notify_text" android:fadingEdge="horizontal" android:layout_width="0dp" android:layout_height="wrap_content" android:singleLine="true" android:layout_weight="1"/>
            <ImageView android:layout_gravity="center" android:id="@+id/theme_notify_right_icon" android:background="@drawable/ic_launcher" android:layout_width="16dp" android:layout_height="16dp" android:layout_marginLeft="10dp" android:scaleType="centerInside" android:layout_weight="0"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
