<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:id="@+id/root" android:background="#ffffff" android:layout_width="match_parent" android:layout_height="match_parent">
    <View android:background="#33000000" android:layout_width="match_parent" android:layout_height="match_parent"/>
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <ImageView android:layout_gravity="top|right" android:id="@+id/close" android:layout_width="@dimen/theme_diy_share_dialog_close_size" android:layout_height="@dimen/theme_diy_share_dialog_close_size" android:layout_marginTop="8dp" android:layout_marginRight="8dp" android:src="@drawable/custom_dialog_close" android:scaleType="fitXY" android:tint="#99333333"/>
            <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="1dp">
                <ImageView android:layout_gravity="center" android:layout_width="@dimen/theme_diy_share_checked_image_size" android:layout_height="@dimen/theme_diy_share_checked_image_size" android:src="@drawable/check_virus_safe" android:scaleType="fitXY" android:alpha="0.7"/>
                <TextView android:textSize="@dimen/theme_diy_share_succ_text_size" android:textColor="#ffffffff" android:gravity="center" android:layout_width="wrap_content" android:layout_height="24.5dp" android:layout_marginLeft="12dp" android:text="@string/theme_changing_succ" android:shadowColor="#ff000000" android:shadowDx="2" android:shadowDy="2" android:shadowRadius="1" android:alpha="0.79"/>
            </LinearLayout>
        </LinearLayout>
        <ImageView android:layout_gravity="center_horizontal" android:id="@+id/screenshot" android:layout_width="wrap_content" android:layout_height="0dp" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:scaleType="centerInside" android:layout_weight="7"/>
        <LinearLayout android:orientation="vertical" android:id="@+id/content" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="2">
            <TextView android:textSize="@dimen/theme_diy_share_tips_text_size" android:textColor="#ccffffff" android:gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="0dp" android:layout_marginLeft="30dp" android:layout_marginRight="30dp" android:text="@string/theme_submit_tips" android:layout_weight="1"/>
            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginLeft="16dp" android:layout_marginRight="16dp" android:layout_weight="1">
                <TextView android:textSize="@dimen/theme_diy_share_btn_text_size" android:textStyle="bold" android:textColor="#ffffffff" android:gravity="center" android:id="@+id/submit_theme_btn" android:background="@drawable/theme_diy_share_btn_selector" android:layout_width="0dp" android:layout_height="@dimen/theme_diy_share_btn_height" android:text="@string/theme_submit_send_to_center" android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
