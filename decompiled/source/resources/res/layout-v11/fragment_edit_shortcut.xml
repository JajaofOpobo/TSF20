<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:orientation="horizontal" android:id="@+id/titlebar" android:background="@drawable/ab_transparent_dark_holo" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginBottom="8dp" android:divider="@drawable/list_divider_holo_dark" android:layout_alignParentTop="true" android:showDividers="middle" android:dividerPadding="16dp">
        <TextView android:textAppearance="?android:attr/textAppearanceLarge" android:gravity="center" android:id="@+id/dialog_title" android:paddingLeft="8dp" android:paddingRight="8dp" android:layout_width="0dp" android:layout_height="match_parent" android:text="@string/theme_picker_edit_shortcut" android:layout_weight="1"/>
        <FrameLayout android:visibility="gone" android:layout_width="56dp" android:layout_height="match_parent" android:layout_weight="0">
            <ImageView android:layout_gravity="center_vertical" android:id="@+id/menu" android:background="@drawable/item_background_holo_dark" android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/ic_menu_moreoverflow_normal_holo_dark" android:scaleType="center"/>
        </FrameLayout>
    </LinearLayout>
    <ImageButton android:id="@+id/icon" android:padding="5dp" android:layout_width="70dp" android:layout_height="70dp" android:layout_marginLeft="12dp" android:src="@drawable/ic_launcher" android:scaleType="centerCrop" android:layout_below="@+id/titlebar" android:layout_alignParentLeft="true"/>
    <AutoCompleteTextView android:id="@+id/label" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginRight="12dp" android:layout_toRightOf="@+id/icon" android:layout_alignBottom="@+id/icon" android:inputType="textNoSuggestions"/>
    <TextView android:typeface="monospace" android:gravity="center" android:id="@+id/component_name" android:padding="8dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:selectAllOnFocus="true" android:layout_below="@+id/label" android:layout_centerInParent="true" android:textIsSelectable="true"/>
    <FrameLayout android:background="#ff333333" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="8dp" android:layout_below="@+id/component_name"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:divider="@drawable/list_divider_holo_dark" android:layout_below="@+id/component_name" android:showDividers="middle" android:dividerPadding="12dp">
        <ImageView android:layout_gravity="center_vertical" android:id="@+id/done" android:background="@drawable/item_background_holo_dark" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_menu_done_holo_dark" android:scaleType="center" android:layout_weight="1"/>
        <ImageView android:layout_gravity="center_vertical" android:id="@+id/reset" android:background="@drawable/item_background_holo_dark" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_undobar_undo" android:scaleType="center" android:layout_weight="1"/>
        <ImageView android:layout_gravity="center_vertical" android:id="@+id/undo" android:background="@drawable/item_background_holo_dark" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_menu_undo_holo_dark" android:scaleType="center" android:layout_weight="1"/>
    </LinearLayout>
</RelativeLayout>
