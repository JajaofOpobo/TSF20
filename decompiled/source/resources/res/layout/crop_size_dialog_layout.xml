<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:paddingBottom="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:orientation="horizontal" android:id="@+id/titlebar" android:background="@drawable/ab_transparent_dark_holo" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:divider="@drawable/list_divider_holo_dark" android:layout_alignParentTop="true">
        <TextView android:textAppearance="?android:attr/textAppearanceLarge" android:gravity="center_vertical" android:id="@+id/dialog_title" android:padding="16dp" android:layout_width="320dp" android:layout_height="match_parent" android:text="Dimensions" android:layout_weight="1"/>
    </LinearLayout>
    <TextView android:textSize="18sp" android:textColor="#ffffff" android:id="@+id/textView1" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Image Size : 2248x3264"/>
    <TextView android:textSize="16sp" android:textColor="#ffffff" android:id="@+id/textView2" android:paddingLeft="16dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Full Crop: 256x256"/>
    <TextView android:textSize="16sp" android:textColor="#ffffff" android:id="@+id/textView3" android:paddingLeft="16dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Protrait Crop: 256x256"/>
    <TextView android:textSize="16sp" android:textColor="#ffffff" android:id="@+id/textView4" android:paddingLeft="16dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Landscape Crop: 256x256"/>
</LinearLayout>
