<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:scrollbars="none" android:layout_width="match_parent" android:layout_height="match_parent">
    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <View android:id="@+id/background" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <View android:background="#33000000" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <ImageView android:id="@+id/btn_back" android:paddingLeft="16dp" android:paddingRight="32dp" android:layout_width="68dp" android:layout_height="20dp" android:layout_marginLeft="9dp" android:layout_marginTop="16dp" android:src="@drawable/back" android:scaleType="centerInside"/>
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginLeft="16dp" android:layout_marginTop="58dp" android:layout_marginRight="16dp">
            <TextView android:textSize="18sp" android:textColor="#ffffff" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="150dp" android:text="@string/theme_submit_name_title"/>
            <FrameLayout android:background="@drawable/upload_wallpaper_edit_bk" android:layout_width="match_parent" android:layout_height="37dp" android:layout_marginTop="12dp">
                <EditText android:textSize="16sp" android:textColor="#ffffff" android:textColorHint="#99ffffff" android:gravity="center_vertical" android:id="@+id/theme_name" android:background="@color/transparent" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginLeft="16dp" android:hint="@string/theme_submit_name_tips" android:singleLine="true"/>
                <ImageView android:layout_gravity="center" android:id="@+id/delete_theme_name" android:layout_width="19dp" android:layout_height="19dp" android:layout_marginTop="14dp" android:layout_marginRight="16dp" android:layout_marginBottom="14dp" android:src="@drawable/icon_search_delete"/>
            </FrameLayout>
            <TextView android:textSize="18sp" android:textColor="#ffffff" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:text="@string/upload_wallpaper_submitpage_titleTip"/>
            <FrameLayout android:background="@drawable/upload_wallpaper_edit_bk" android:layout_width="match_parent" android:layout_height="37dp" android:layout_marginTop="12dp">
                <EditText android:textSize="16sp" android:textColor="#ffffff" android:textColorHint="#99ffffff" android:gravity="center_vertical" android:id="@+id/user_name" android:background="@color/transparent" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginLeft="16dp" android:hint="@string/theme_submit_user_name_tips" android:singleLine="true"/>
                <ImageView android:layout_gravity="center" android:id="@+id/delete_user_name" android:layout_width="19dp" android:layout_height="19dp" android:layout_marginTop="14dp" android:layout_marginRight="16dp" android:layout_marginBottom="14dp" android:src="@drawable/icon_search_delete"/>
            </FrameLayout>
            <FrameLayout android:background="@drawable/upload_wallpaper_edit_bk" android:layout_width="match_parent" android:layout_height="37dp" android:layout_marginTop="10dp">
                <EditText android:textSize="16sp" android:textColor="#ffffff" android:textColorHint="#99ffffff" android:gravity="center_vertical" android:id="@+id/user_email" android:background="@color/transparent" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginLeft="16dp" android:hint="@string/theme_submit_user_email_tips" android:singleLine="true"/>
                <ImageView android:layout_gravity="center" android:id="@+id/delete_user_email" android:layout_width="19dp" android:layout_height="19dp" android:layout_marginTop="14dp" android:layout_marginRight="16dp" android:layout_marginBottom="14dp" android:src="@drawable/icon_search_delete"/>
            </FrameLayout>
            <TextView android:textSize="13sp" android:textColor="#b2ffffff" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="@string/theme_submit_copyright"/>
            <TextView android:textSize="16sp" android:textColor="#ffffff" android:gravity="center" android:layout_gravity="bottom" android:id="@+id/btn_commit" android:background="@drawable/theme_diy_btn_selector" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="18dp" android:layout_marginBottom="10dp" android:text="@string/wallpaper_upload_text"/>
        </LinearLayout>
    </FrameLayout>
</ScrollView>
