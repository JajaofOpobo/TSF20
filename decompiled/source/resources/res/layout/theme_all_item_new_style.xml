<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:orientation="vertical" android:id="@+id/theme_item_left" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_weight="1">
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.tsf.extend.base.view.RoundedImageView android:id="@+id/theme_img_left" android:background="@drawable/theme_list_item_bg" android:layout_width="match_parent" android:layout_height="wrap_content" android:scaleType="fitXY" app:riv_corner_radius="@dimen/theme_list_image_corner_radius"/>
            <com.tsf.extend.base.view.RoundedImageView android:layout_gravity="top|left" android:id="@+id/suggest_left" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/theme_recommend" app:riv_corner_radius_top_left="@dimen/theme_list_image_corner_radius"/>
        </FrameLayout>
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/theme_item_download_layout_left" android:layout_width="match_parent" android:layout_height="@dimen/theme_download_layout_height">
            <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <TextView android:textSize="10sp" android:textColor="#80333333" android:ellipsize="end" android:gravity="center_vertical" android:id="@+id/theme_down_left" android:layout_width="wrap_content" android:layout_height="wrap_content" android:singleLine="true" android:drawablePadding="6dp"/>
            </FrameLayout>
            <ImageView android:id="@+id/theme_download_left" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_marginLeft="8dp" android:src="@drawable/theme_downloads_icon"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:id="@+id/theme_item_mid" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_weight="1">
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.tsf.extend.base.view.RoundedImageView android:id="@+id/theme_img_mid" android:background="@drawable/theme_list_item_bg" android:layout_width="match_parent" android:layout_height="wrap_content" android:scaleType="fitXY" app:riv_corner_radius="@dimen/theme_list_image_corner_radius"/>
            <com.tsf.extend.base.view.RoundedImageView android:layout_gravity="top|left" android:id="@+id/suggest_mid" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/theme_recommend" app:riv_corner_radius_top_left="@dimen/theme_list_image_corner_radius"/>
        </FrameLayout>
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/theme_item_download_layout_mid" android:layout_width="match_parent" android:layout_height="@dimen/theme_download_layout_height">
            <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <TextView android:textSize="10sp" android:textColor="#80333333" android:ellipsize="end" android:gravity="center_vertical" android:id="@+id/theme_down_mid" android:layout_width="wrap_content" android:layout_height="wrap_content" android:singleLine="true" android:drawablePadding="6dp"/>
            </FrameLayout>
            <ImageView android:id="@+id/theme_download_mid" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_marginLeft="8dp" android:src="@drawable/theme_downloads_icon"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:id="@+id/theme_item_right" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_weight="1">
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.tsf.extend.base.view.RoundedImageView android:id="@+id/theme_img_right" android:background="@drawable/theme_list_item_bg" android:layout_width="match_parent" android:layout_height="wrap_content" android:scaleType="fitXY" app:riv_corner_radius="@dimen/theme_list_image_corner_radius"/>
            <com.tsf.extend.base.view.RoundedImageView android:layout_gravity="top|left" android:id="@+id/suggest_right" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/theme_recommend" app:riv_corner_radius_top_left="@dimen/theme_list_image_corner_radius"/>
        </FrameLayout>
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/theme_item_download_layout_right" android:layout_width="match_parent" android:layout_height="@dimen/theme_download_layout_height">
            <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <TextView android:textSize="10sp" android:textColor="#80333333" android:ellipsize="end" android:gravity="center_vertical" android:id="@+id/theme_down_right" android:layout_width="wrap_content" android:layout_height="wrap_content" android:singleLine="true" android:drawablePadding="6dp"/>
            </FrameLayout>
            <ImageView android:id="@+id/theme_download_right" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_marginLeft="8dp" android:src="@drawable/theme_downloads_icon"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
