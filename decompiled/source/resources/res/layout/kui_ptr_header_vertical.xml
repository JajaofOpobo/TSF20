<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:id="@+id/fl_inner" android:paddingLeft="@dimen/ptr_header_footer_left_right_padding" android:paddingTop="@dimen/ptr_header_footer_top_bottom_padding" android:paddingRight="@dimen/ptr_header_footer_left_right_padding" android:paddingBottom="@dimen/ptr_header_footer_top_bottom_padding" android:layout_width="match_parent" android:layout_height="wrap_content" android:weightSum="2">
        <View android:layout_width="0dp" android:layout_height="1px" android:layout_weight="1"/>
        <FrameLayout android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="5dp">
            <ImageView android:layout_gravity="center" android:id="@+id/pull_to_refresh_image" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <ProgressBar android:layout_gravity="center" android:id="@+id/pull_to_refresh_progress" android:visibility="gone" android:layout_width="25dp" android:layout_height="25dp" android:indeterminate="true" style="@style/pulltorefresh_progress"/>
        </FrameLayout>
        <LinearLayout android:gravity="center_horizontal" android:layout_gravity="center" android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:textSize="12.5sp" android:gravity="center" android:id="@+id/pull_to_refresh_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="@dimen/pull_to_refresh_text_width" android:singleLine="true" style="@style/pullRefreshTitle"/>
            <TextView android:textSize="12sp" android:id="@+id/pull_to_refresh_sub_text" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:singleLine="true" style="@style/pullRefreshTitle"/>
        </LinearLayout>
        <View android:layout_width="0dp" android:layout_height="1px" android:layout_weight="1"/>
    </LinearLayout>
</merge>
