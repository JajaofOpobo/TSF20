<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent">
    <RelativeLayout android:background="@drawable/plugin_floating_widget_picker_setting_bg" android:padding="0dp" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="20dp">
        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginLeft="22dp" android:layout_marginTop="12dp" android:layout_marginRight="22dp" android:layout_marginBottom="12dp">
            <ListView android:scrollbarThumbVertical="@drawable/plugin_floating_widget_picker_scrollbar" android:id="@+id/listView1" android:layout_width="90dp" android:layout_height="match_parent" android:layout_alignParentLeft="true" android:layout_centerVertical="true"/>
            <ListView android:scrollbarThumbVertical="@drawable/plugin_floating_widget_picker_scrollbar" android:id="@+id/listView2" android:layout_width="match_parent" android:layout_height="match_parent" android:divider="@drawable/plugin_floating_widget_picker_item_line" android:layout_toRightOf="@+id/listView1" android:layout_centerVertical="true"/>
        </RelativeLayout>
