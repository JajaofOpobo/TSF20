            <View android:background="@color/dialog_divider_color" android:layout_width="0.5dp" android:layout_height="match_parent"/>
            <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="#4480f7" android:gravity="center" android:id="@+id/share_theme_btn" android:background="@drawable/bottom_style_dialog_btn_selector" android:layout_width="0dp" android:layout_height="48dp" android:text="@string/theme_submit_rating" android:layout_weight="1"/>
