<?xml version="1.0" encoding="utf-8"?>
<com.tsf.extend.wallpaper.PersonalizationPager xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:paddingTop="@dimen/workspace_margin_top" android:layout_width="match_parent" android:layout_height="match_parent">
    <FrameLayout android:id="@+id/container" android:background="#ffeeeeee" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <View android:layout_gravity="bottom" android:background="#33000000" android:layout_width="match_parent" android:layout_height="0.5dp"/>
    </FrameLayout>
    <LinearLayout android:orientation="horizontal" android:background="#ffeeeeee" android:layout_width="match_parent" android:layout_height="56dp" android:baselineAligned="false">
        <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@+id/tab_theme" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageView android:id="@+id/tab_theme_icon" android:duplicateParentState="true" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:textSize="11sp" android:textColor="@color/personalize_text_color_selector" android:duplicateParentState="true" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/theme" android:singleLine="true"/>
        </LinearLayout>
        <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@+id/tab_wallpaper" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageView android:id="@+id/tab_wallpaper_icon" android:duplicateParentState="true" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:textSize="11sp" android:textColor="@color/personalize_text_color_selector" android:duplicateParentState="true" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/wallpaper_tab" android:singleLine="true"/>
        </LinearLayout>
        <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@+id/tab_keyboard" android:visibility="gone" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageView android:id="@+id/tab_keyboard_icon" android:duplicateParentState="true" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:textSize="11sp" android:textColor="@color/personalize_text_color_selector" android:duplicateParentState="true" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/keyboard_tab" android:singleLine="true"/>
        </LinearLayout>
    </LinearLayout>
</com.tsf.extend.wallpaper.PersonalizationPager>
