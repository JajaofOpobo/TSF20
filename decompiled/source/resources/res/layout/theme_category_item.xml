<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="40dp">
    <FrameLayout android:layout_gravity="center_horizontal" android:id="@+id/theme_color" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_gravity="center" android:orientation="horizontal" android:id="@+id/theme_color_layout" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </FrameLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/theme_lable" android:layout_width="match_parent" android:layout_height="wrap_content">
        <FrameLayout android:orientation="vertical" android:id="@+id/theme_category_item_left" android:paddingLeft="7dp" android:paddingRight="6dp" android:paddingBottom="13dp" android:layout_width="match_parent" android:layout_height="88dp" android:layout_weight="1">
            <ImageView android:id="@+id/theme_category_img_left" android:background="@color/personal_list_item_bg" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitXY"/>
            <TextView android:textSize="18sp" android:textColor="#ffffffff" android:ellipsize="end" android:layout_gravity="center" android:id="@+id/theme_category_name_left" android:paddingLeft="8dp" android:paddingRight="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:singleLine="true"/>
        </FrameLayout>
        <FrameLayout android:orientation="vertical" android:id="@+id/theme_category_item_right" android:paddingLeft="6dp" android:paddingRight="7dp" android:paddingBottom="13dp" android:layout_width="match_parent" android:layout_height="88dp" android:layout_weight="1">
            <ImageView android:id="@+id/theme_category_img_right" android:background="@color/personal_list_item_bg" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitXY"/>
            <TextView android:textSize="18sp" android:textColor="#ffffffff" android:ellipsize="end" android:layout_gravity="center" android:id="@+id/theme_category_name_right" android:paddingLeft="8dp" android:paddingRight="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:singleLine="true"/>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
