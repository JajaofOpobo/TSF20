<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
    <ImageView android:id="@+id/wallpaper" android:layout_width="match_parent" android:layout_height="0dp" android:scaleType="fitCenter" android:layout_weight="1"/>
    <Gallery android:id="@+id/gallery" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <Button android:textSize="15sp" android:layout_gravity="center_horizontal" android:id="@+id/set" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/wallpaper_instructions"/>
</LinearLayout>
