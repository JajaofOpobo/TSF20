<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:gravity="center_vertical" android:id="@+id/k_title" android:background="#ff233647" android:layout_width="match_parent" android:layout_height="48dp">
    <RelativeLayout android:id="@+id/title_head" android:layout_width="match_parent" android:layout_height="match_parent">
        <TextView android:textSize="20sp" android:textColor="@color/white" android:gravity="center_vertical" android:id="@+id/title_back" android:paddingLeft="16dp" android:paddingRight="10dp" android:visibility="visible" android:layout_width="match_parent" android:layout_height="match_parent" android:singleLine="true" android:drawableLeft="@drawable/actionbar_back_title" android:drawablePadding="16dp" android:layout_alignParentLeft="true"/>
        <Button android:textSize="20sp" android:textColor="@color/white" android:layout_gravity="center" android:id="@+id/action_btn" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="match_parent" android:minWidth="50dp" android:singleLine="true" android:layout_alignParentRight="true"/>
        <ImageButton android:textSize="20sp" android:textColor="@color/white" android:layout_gravity="center" android:id="@+id/action_img_btn" android:padding="13dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="match_parent" android:singleLine="true" android:layout_alignParentRight="true"/>
    </RelativeLayout>
</FrameLayout>
