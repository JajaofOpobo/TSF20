<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="match_parent">
    <ImageView android:id="@+id/image_icon" android:layout_width="wrap_content" android:layout_height="match_parent" android:src="@drawable/ic_launcher" android:scaleType="fitXY" android:minWidth="64dp" android:minHeight="64dp" android:contentDescription="@null"/>
    <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginLeft="16dp" android:layout_weight="1">
        <TextView android:textSize="14sp" android:ellipsize="end" android:gravity="top" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/upload_wallpaper_submitting" android:maxLines="2"/>
        <ProgressBar android:id="@+id/progress" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" style="@android:style/Widget.DeviceDefault.ProgressBar.Horizontal"/>
    </LinearLayout>
    <ImageView android:layout_gravity="center_vertical" android:id="@+id/image_right" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_marginLeft="10dp" android:layout_marginRight="16dp" android:src="@drawable/tip_close" android:contentDescription="@null"/>
</LinearLayout>
