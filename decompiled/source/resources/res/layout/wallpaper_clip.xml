<?xml version="1.0" encoding="utf-8"?>
<com.tsf.extend.wallpaper.WallpaperClip xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent">
    <View android:layout_gravity="bottom" android:id="@+id/bg_bottom" android:background="@drawable/wallpaper_gradient_bg_bottom" android:layout_width="match_parent" android:layout_height="250dp"/>
    <View android:layout_gravity="top" android:id="@+id/bg_top" android:background="@drawable/wallpaper_gradient_bg_top" android:layout_width="match_parent" android:layout_height="135dp"/>
    <LinearLayout android:orientation="vertical" android:background="@color/wallpaper_list_bg" android:layout_width="match_parent" android:layout_height="match_parent">
        <FrameLayout android:background="@drawable/wallpaper_mine_bg_selector" android:layout_width="match_parent" android:layout_height="38dp">
            <TextView android:textSize="19sp" android:textColor="#ffffff" android:gravity="center" android:id="@+id/wp_clip_title" android:background="@color/wallpaper_clip_shadow" android:paddingLeft="9dp" android:paddingRight="9dp" android:layout_width="match_parent" android:layout_height="38dp" android:text="@string/wp_clip_title" android:drawableLeft="@drawable/back" android:drawablePadding="6dp"/>
        </FrameLayout>
        <FrameLayout android:id="@+id/wp_clip_wallpaper_root" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <com.tsf.extend.wallpaper.WallpaperClipImageView android:id="@+id/wp_clip_launcher_clip_preview" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <com.tsf.extend.wallpaper.CustomWallpaperShadowView android:id="@+id/wallpaper_shadow" android:layout_width="match_parent" android:layout_height="match_parent"/>
            <TextView android:textSize="12sp" android:textColor="#66ffffff" android:gravity="top|center_horizontal" android:paddingTop="7dp" android:paddingBottom="6dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/wp_clip_mv_zm_hint"/>
            <LinearLayout android:gravity="center_horizontal" android:layout_gravity="center" android:orientation="vertical" android:id="@+id/wp_clip_setting_wallpaper" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <ProgressBar android:id="@+id/wp_clip_setting_wallpaper_progress" android:layout_width="70dp" android:layout_height="70dp"/>
                <TextView android:textSize="16sp" android:textColor="@color/white" android:id="@+id/wp_clip_progress_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="21dp" android:text="@string/setting_wallpaper"/>
            </LinearLayout>
            <LinearLayout android:gravity="center" android:layout_gravity="bottom" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="20dp" android:layout_marginRight="20dp" android:layout_marginBottom="10dp">
                <TextView android:textColor="#99ffffff" android:ellipsize="end" android:gravity="center" android:id="@+id/wp_clip_single_screen" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/wp_clip_single_screen_mode" android:singleLine="true" android:drawableTop="@drawable/wp_clip_fix_on_bt" android:drawablePadding="3dp" android:layout_weight="1"/>
                <TextView android:textColor="#99ffffff" android:ellipsize="end" android:gravity="center" android:id="@+id/wp_clip_muti_screen" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/wp_clip_scroll_screen_mode" android:singleLine="true" android:drawableTop="@drawable/wp_clip_scrollable_off_bt" android:drawablePadding="3dp" android:layout_weight="1"/>
            </LinearLayout>
        </FrameLayout>
        <FrameLayout android:background="#26ffffff" android:layout_width="match_parent" android:layout_height="1dp">
            <View android:background="@color/wallpaper_clip_shadow" android:layout_width="match_parent" android:layout_height="1dp"/>
        </FrameLayout>
        <FrameLayout android:layout_gravity="bottom" android:background="#19000000" android:layout_width="match_parent" android:layout_height="48dp">
            <LinearLayout android:gravity="center_vertical" android:layout_gravity="bottom" android:orientation="horizontal" android:background="@color/wallpaper_clip_shadow" android:layout_width="match_parent" android:layout_height="48dp" android:weightSum="1">
                <ImageView android:gravity="center" android:id="@+id/wp_clip_preview_bt" android:paddingLeft="24dp" android:paddingRight="24dp" android:layout_width="wrap_content" android:layout_height="match_parent" android:src="@drawable/wallpaper_preview_btn"/>
                <TextView android:textSize="16sp" android:textColor="@drawable/set_wallpaper_text_color" android:ellipsize="end" android:gravity="center" android:id="@+id/wp_clip_set_wallpaper_bt" android:paddingLeft="12dp" android:paddingRight="12dp" android:layout_width="0dp" android:layout_height="wrap_content" android:minHeight="47dp" android:text="@string/set_as_wallpaper" android:maxLines="2" android:layout_weight="1"/>
                <View android:paddingLeft="24dp" android:paddingRight="24dp" android:visibility="invisible" android:layout_width="78dp" android:layout_height="match_parent"/>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
    <ImageView android:id="@+id/wp_clip_preview" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitXY"/>
</com.tsf.extend.wallpaper.WallpaperClip>
