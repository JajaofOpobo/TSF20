<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="horizontal" android:paddingLeft="16dp" android:paddingTop="13dp" android:paddingRight="16dp" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:orientation="vertical" android:id="@+id/left_layout" android:layout_width="match_parent" android:layout_height="match_parent">
        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <ImageView android:id="@+id/theme_img_left" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitXY"/>
            <ImageView android:layout_gravity="top|right" android:id="@+id/theme_using_left" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/theme_using" android:scaleType="fitXY"/>
        </FrameLayout>
        <TextView android:textSize="12sp" android:textColor="#ff000000" android:ellipsize="end" android:layout_gravity="center_horizontal" android:id="@+id/theme_name_left" android:paddingTop="4dp" android:layout_width="wrap_content" android:layout_height="@dimen/theme_name_layout_height" android:singleLine="true"/>
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:id="@+id/center_layout" android:layout_width="match_parent" android:layout_height="match_parent">
        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <ImageView android:id="@+id/theme_img_center" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitXY"/>
            <ImageView android:layout_gravity="top|right" android:id="@+id/theme_using_center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/theme_using" android:scaleType="fitXY"/>
        </FrameLayout>
        <TextView android:textSize="12sp" android:textColor="#ff000000" android:ellipsize="end" android:layout_gravity="center_horizontal" android:id="@+id/theme_name_center" android:paddingTop="4dp" android:layout_width="wrap_content" android:layout_height="@dimen/theme_name_layout_height" android:singleLine="true"/>
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:id="@+id/right_layout" android:layout_width="match_parent" android:layout_height="match_parent">
        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <ImageView android:id="@+id/theme_img_right" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitXY"/>
            <ImageView android:layout_gravity="top|right" android:id="@+id/theme_using_right" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/theme_using" android:scaleType="fitXY"/>
        </FrameLayout>
        <TextView android:textSize="12sp" android:textColor="#ff000000" android:ellipsize="end" android:layout_gravity="center_horizontal" android:id="@+id/theme_name_right" android:paddingTop="4dp" android:layout_width="wrap_content" android:layout_height="@dimen/theme_name_layout_height" android:singleLine="true"/>
    </LinearLayout>
</LinearLayout>
